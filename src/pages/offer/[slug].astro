---
export async function getStaticPaths() {
  const WP_USER     = import.meta.env.WP_USER;
  const WP_APP_PASS = import.meta.env.WP_APP_PASS;

  if (!WP_USER || !WP_APP_PASS) {
    throw new Error('[offer/slug] Missing WP_USER or WP_APP_PASS env vars.');
  }

  const authHeader = 'Basic ' + btoa(`${WP_USER}:${WP_APP_PASS}`);

  // Paginated — fetches all affiliate links regardless of count
  const allLinks: any[] = [];
  let page = 1;
  while (true) {
    const res = await fetch(
      `https://androidscroll.com/wp-json/wp/v2/thirstylink?per_page=100&page=${page}&_fields=slug,meta`,
      { headers: { Authorization: authHeader } }
    );
    if (!res.ok) break;
    const batch = await res.json();
    if (!batch.length) break;
    allLinks.push(...batch);
    const totalPages = Number(res.headers.get('X-WP-TotalPages') ?? 1);
    if (page >= totalPages) break;
    page++;
  }
  const links = allLinks;

  return links
    .map((link: any) => {
      const raw = link.meta?._ta_destination_url ?? '';

      // Validate at build time — only allow http/https URLs.
      // Blocks javascript:, data:, vbscript:, and anything non-HTTP.
      let safeDestination = '';
      try {
        const u = new URL(raw);
        if (u.protocol === 'https:' || u.protocol === 'http:') {
          safeDestination = u.href;
        }
      } catch {
        // Unparseable URL — leave safeDestination empty
      }

      return {
        params: { slug: link.slug },
        props: { destination: safeDestination },
      };
    })
    // Drop entries where destination didn't pass validation
    .filter((entry: any) => entry.props.destination !== '');
}

const { destination } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content={`0;url=${destination}`} />
    <title>Redirecting...</title>
  </head>
  <body>
    <p>Redirecting... <a href={destination} rel="noopener noreferrer">Click here if nothing happens.</a></p>
    <script define:vars={{ destination }}>
      window.location.replace(destination);
    </script>
  </body>
</html>