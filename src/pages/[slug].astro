<button id="as-back-to-top" aria-label="Back to top"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M18 15l-6-6-6 6"/></svg></button>

{tocHeadings.length > 2 && (
  <div id="as-sticky-toc" class="as-sticky-toc" aria-hidden="true">
    <div id="as-stp" class="as-stp" role="dialog" aria-label="Table of Contents">
      <p class="as-stp-title">Contents</p>
      <ul>
        {tocHeadings.map(h => <li><a href={`#${h.slug}`}>{h.text}</a></li>)}
      </ul>
    </div>
    <button id="as-sticky-toc-btn" aria-label="Table of Contents" aria-expanded="false" aria-controls="as-stp">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="16" y2="12"/><line x1="3" y1="18" x2="11" y2="18"/></svg>
    </button>
  </div>
)}
<script>
  const pb = document.getElementById('as-progress-bar'); if(pb){window.addEventListener('scroll',()=>{const t=window.scrollY;const h=document.documentElement.scrollHeight-window.innerHeight;pb.style.width=(h>0?t/h*100:0)+'%'})}
  const btt=document.getElementById('as-back-to-top');if(btt){window.addEventListener('scroll',()=>btt.classList.toggle('show',window.scrollY>600));btt.addEventListener('click',()=>window.scrollTo({top:0,behavior:'smooth'}))}
  const toc=document.getElementById('as-toc');const th=document.getElementById('toc-header');if(toc&&th){if(localStorage.getItem('toc-open')==='true')toc.classList.remove('toc-collapsed');th.addEventListener('click',()=>{toc.classList.toggle('toc-collapsed');localStorage.setItem('toc-open',!toc.classList.contains('toc-collapsed'))})}
  // Sticky TOC float
  const stoc = document.getElementById('as-sticky-toc');
  const stocBtn = document.getElementById('as-sticky-toc-btn');
  const stocPanel = document.getElementById('as-stp');
  if(stoc && stocBtn && stocPanel) {
    // Show after scrolling ~300px, hide when bottom share section is visible
    const bottomShare = document.getElementById('as-bottom-share');
    let panelOpen = false;
    const togglePanel = (force?: boolean) => {
      panelOpen = force !== undefined ? force : !panelOpen;
      stocPanel.classList.toggle('as-stp-open', panelOpen);
      stocBtn.setAttribute('aria-expanded', String(panelOpen));
    };
    stocBtn.addEventListener('click', (e) => { e.stopPropagation(); togglePanel(); });
    stocPanel.querySelectorAll('a').forEach(a => a.addEventListener('click', () => togglePanel(false)));
    document.addEventListener('click', (e) => { if(panelOpen && !stoc.contains(e.target as Node)) togglePanel(false); });
    // Show only when inline TOC has scrolled out of view; hide when bottom share is visible
    const inlineToc = document.getElementById('as-toc');
    let inlineTocGone = false;
    let bottomShareVisible = false;
    const updateVisibility = () => {
      const show = inlineTocGone && !bottomShareVisible;
      stoc.classList.toggle('as-sticky-toc-visible', show);
      stoc.classList.toggle('as-sticky-toc-hidden', !show);
      if (!show) togglePanel(false);
    };
    if (inlineToc) {
      const tocObs = new IntersectionObserver(([entry]) => {
        inlineTocGone = !entry.isIntersecting;
        updateVisibility();
      }, { threshold: 0 });
      tocObs.observe(inlineToc);
    }
    if (bottomShare) {
      const shareObs = new IntersectionObserver(([entry]) => {
        bottomShareVisible = entry.isIntersecting;
        updateVisibility();
      }, { threshold: 0.1 });
      shareObs.observe(bottomShare);
    }
  }
  // Social share links — deferred to avoid forced reflow during initial paint
  requestAnimationFrame(() => {
    const url = encodeURIComponent(location.href);
    const shareTitle = encodeURIComponent(document.title);
    const coverImg = encodeURIComponent(document.getElementById('featured-image')?.src || document.querySelector('article img')?.src || '');
    // Bottom share
    const fbEl = document.getElementById('share-fb');
    const xEl = document.getElementById('share-x');
    const pinEl = document.getElementById('share-pinterest');
    const waEl = document.getElementById('share-whatsapp');
    if(fbEl) fbEl.href = `https://www.facebook.com/sharer/sharer.php?u=${url}`;
    if(xEl) xEl.href = `https://x.com/intent/tweet?url=${url}&text=${shareTitle}`;
    if(pinEl) pinEl.href = `https://pinterest.com/pin/create/button/?url=${url}&media=${coverImg}&description=${shareTitle}`;
    if(waEl) waEl.href = `https://wa.me/?text=${shareTitle}%20${url}`;
    const thEl = document.getElementById('btn-threads-share'); if(thEl) thEl.href = `https://www.threads.net/intent/post?text=${encodeURIComponent(document.title + ' ' + window.location.href)}`;
    const sb=document.getElementById('native-share-btn');if(sb&&navigator.share){sb.style.display='inline-flex';sb.addEventListener('click',()=>navigator.share({title:document.title,url:location.href}))}
    // Top share (icon-only)
    const tFb = document.getElementById('top-share-fb'); if(tFb) tFb.href = `https://www.facebook.com/sharer/sharer.php?u=${url}`;
    const tX  = document.getElementById('top-share-x');  if(tX)  tX.href  = `https://x.com/intent/tweet?url=${url}&text=${shareTitle}`;
    const tWa = document.getElementById('top-share-wa'); if(tWa) tWa.href = `https://wa.me/?text=${shareTitle}%20${url}`;
    const tPin= document.getElementById('top-share-pinterest'); if(tPin) tPin.href = `https://pinterest.com/pin/create/button/?url=${url}&media=${coverImg}&description=${shareTitle}`;
    const tTh = document.getElementById('top-share-threads'); if(tTh) tTh.href = `https://www.threads.net/intent/post?text=${encodeURIComponent(document.title + ' ' + window.location.href)}`;
    const tNs = document.getElementById('top-native-share-btn'); if(tNs&&navigator.share){tNs.style.display='inline-flex';tNs.addEventListener('click',()=>navigator.share({title:document.title,url:location.href}))}
  });
</script>

<style>
  /* Breadcrumbs — merged with category pill */
  .as-breadcrumbs {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 14px;
    line-height: 1.4;
  }
  .as-bc-home { color: var(--text-muted); text-decoration: none; }
  .as-bc-home:hover { color: var(--color-primary, #00a896); }
  .as-bc-sep { opacity: 0.45; font-size: 11px; }
  .category_meta-pill {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    border-radius: 999px;
    border: 1.5px solid var(--color-primary, #00a896);
    color: var(--color-primary, #00a896);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .category_meta-pill:hover {
    background: var(--color-primary, #00a896);
    color: #fff;
  }

  /* Sticky TOC float — mirrors back-to-top exactly: same bottom, size, opacity, color */
  .as-sticky-toc {
    position: fixed;
    bottom: 80px; /* same as #as-back-to-top.show bottom value */
    left: 20px;   /* left side, parallel to back-to-top on the right */
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: all 0.4s ease; /* matches back-to-top transition */
  }
  .as-sticky-toc.as-sticky-toc-visible {
    opacity: 0.75; /* matches back-to-top.show opacity */
    visibility: visible;
    pointer-events: auto;
  }
  .as-sticky-toc.as-sticky-toc-visible:hover { opacity: 1; }
  .as-sticky-toc.as-sticky-toc-hidden { opacity: 0 !important; visibility: hidden !important; pointer-events: none !important; }

  #as-sticky-toc-btn {
    width: 42px; height: 42px;   /* exact same size as back-to-top */
    border-radius: 50%;
    background-color: var(--brand-primary); /* exact same as back-to-top */
    border: none;
    box-shadow: 0 4px 10px rgba(0,0,0,0.15); /* exact same as back-to-top */
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    color: var(--bg-body); /* exact same as back-to-top */
    transition: all 0.4s ease;
  }
  #as-sticky-toc-btn:hover { background-color: var(--brand-hover); transform: translateY(-3px); }

  /* TOC panel — opens upward from left button, capped height with scroll */
  .as-stp {
    position: absolute;
    bottom: calc(100% + 10px);
    left: 0;
    right: auto;
    width: 240px;
    max-height: 55vh;
    overflow-y: auto;
    overscroll-behavior: contain;
    background: var(--bg-surface);
    border: 1.5px solid var(--border-light);
    border-radius: var(--radius-main);
    box-shadow: 0 4px 20px rgba(0,0,0,0.13);
    padding: 14px 16px;
    opacity: 0;
    pointer-events: none;
    transform: translateY(6px);
    transition: opacity 0.18s, transform 0.18s;
  }
  .as-stp.as-stp-open { opacity: 1; pointer-events: auto; transform: translateY(0); }
  .as-stp-title {
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.8px; color: var(--text-muted); margin-bottom: 10px;
  }
  .as-stp ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 2px; }
  .as-stp li a {
    display: block; font-size: 13px; color: var(--text-dark);
    text-decoration: none; padding: 5px 8px; border-radius: 6px;
    transition: background 0.12s, color 0.12s;
    line-height: 1.4;
  }
  .as-stp li a:hover { background: var(--bg-surface-2, #f5f5f5); color: var(--color-primary, #00a896); }

  /* Compact top share icons */
  .as-top-share {
    display: flex;
    align-items: center;
    gap: 7px;
    margin: 10px 0 18px;
    flex-wrap: wrap;
  }
  .as-top-share-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: var(--text-muted);
    margin-right: 2px;
  }
  .as-tsi {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1.5px solid var(--border-light);
    background: var(--bg-surface-2, #f5f5f5);
    color: var(--text-dark);
    text-decoration: none;
    transition: transform 0.15s, border-color 0.15s;
    cursor: pointer;
    padding: 0;
  }
  .as-tsi:hover { transform: scale(1.1); border-color: var(--color-primary, #00a896); }
  .as-tsi-fb:hover { background: #1877F2; color: #fff; border-color: #1877F2; }
  .as-tsi-x:hover  { background: #000; color: #fff; border-color: #000; }
  .as-tsi-wa:hover { background: #25D366; color: #fff; border-color: #25D366; }
  .as-tsi-pin:hover { background: #E60023; color: #fff; border-color: #E60023; }
  .as-tsi-th:hover { background: #000; color: #fff; border-color: #000; }

  /* Google News follow button */
  .as-gn-follow-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 18px;
    border-radius: var(--radius-main);
    background: var(--bg-surface-2, #f5f5f5);
    border: 1.5px solid var(--border-light);
    color: var(--text-dark);
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .as-gn-follow-btn:hover { border-color: #4285F4; background: var(--bg-surface); }
  .as-gn-follow-btn svg { flex-shrink: 0; border-radius: 50%; box-shadow: 0 0 0 1px #e0e0e0; }
</style>
