---
import Layout from '../layouts/Layout.astro';
import { getAllPosts, getPosts, getCategories, getRankMathHead, getComments, withConcurrency, decode} from '../lib/wp';
import Comments from '../components/Comments.astro';
import { createHash } from 'crypto';
import { serverSanitizeHtml } from '../lib/server-sanitize';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  // FIX: withConcurrency(15) replaces Promise.all(posts.map(...)) — previously fired
  // N simultaneous requests to Hostinger which causes timeouts at scale (200+ posts).
  // 15 concurrent requests at a time is safe and still fast.
  const [heads, commentsArr] = await Promise.all([
    withConcurrency(posts, (p: any) => getRankMathHead(p.slug)),
    withConcurrency(posts, (p: any) => getComments(p.id)),
  ]);
  return posts.map((p: any, i: number) => ({
    params: { slug: p.slug },
    props: { post: p, rankMathHead: heads[i], buildComments: commentsArr[i] },
  }));
}

const { post, rankMathHead, buildComments } = Astro.props;
if (!post) return Astro.redirect('/404');
if (!rankMathHead) console.warn(`[SEO] RankMath returned null for: ${post.slug} — fallback meta in use, no schema injected`);
const allCats = await getCategories();

const title = decode(post.title.rendered.replace(/<[^>]+>/g,''));
const description = decode(post.excerpt.rendered.replace(/<[^>]+>/g,'').trim());
const cover = post._embedded?.['wp:featuredmedia']?.[0]?.source_url || null;
const coverAlt    = post._embedded?.['wp:featuredmedia']?.[0]?.alt_text || title;
const coverWidth  = post._embedded?.['wp:featuredmedia']?.[0]?.media_details?.width  || null;
const coverHeight = post._embedded?.['wp:featuredmedia']?.[0]?.media_details?.height || null;
const AUTHOR_EMAIL  = import.meta.env.AUTHOR_EMAIL ?? '';
const gravatarHash  = createHash('md5').update(AUTHOR_EMAIL.trim().toLowerCase()).digest('hex');
const authorAvatar  = `https://www.gravatar.com/avatar/${gravatarHash}?s=100`;
const date = new Date(post.date);
const modified = new Date(post.modified);
const isUpdated = post.modified && post.modified.slice(0, 10) !== post.date.slice(0, 10);

// reading time
const wordCount = post.content.rendered.replace(/<[^>]+>/g,' ').split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 238));

// add IDs to H2 for TOC
let i = 0;
let contentHtml = post.content.rendered.replace(/<h2([^>]*)>(.*?)<\/h2>/gi, (m, a, t) => {
  const id = `h2-${i++}`;
  return `<h2 id="${id}"${a}>${t}</h2>`;
});
const tocHeadings = [...contentHtml.matchAll(/<h2 id="([^"]*)"[^>]*>(.*?)<\/h2>/gi)].map(m => ({ slug: m[1], text: decode(m[2].replace(/<[^>]+>/g,'')) }));

// Post IDs to exclude from TOC — add WordPress post IDs here
const tocExcludedIds: number[] = [
56  // e.g. 123, 456
];

// Build TOC HTML and inject before first H2
const tocHtml = tocHeadings.length > 2 && !tocExcludedIds.includes(post.id)
  ? `<div class="android-scroll-toc toc-collapsed" id="as-toc" style="margin-bottom:30px; margin-top:0px;"><div class="toc-header" id="toc-header"><span class="toc-title">📋 Table of Contents</span><span class="toc-toggle" id="toc-toggle"></span></div><ul class="toc-list" id="toc-list">${tocHeadings.map(h => `<li><a href="#${h.slug}">${h.text}</a></li>`).join('')}</ul></div>`
  : '';
if (tocHtml) {
  contentHtml = contentHtml.replace(/<h2/, tocHtml + '<h2');
}

// Sanitize at build time — strips scripts, iframes, dangerous attrs, javascript: URLs
contentHtml = serverSanitizeHtml(contentHtml);

// breadcrumb — first category + parent if subcategory
const bcCat = post._embedded?.['wp:term']?.[0]?.[0] || null;
const bcCatFull = bcCat ? allCats.find((c: any) => c.id === bcCat.id) : null;
const bcParent = bcCatFull?.parent ? allCats.find((c: any) => c.id === bcCatFull.parent) : null;
const bcCatHref = bcParent ? `/category/${bcParent.slug}/${bcCat?.slug}` : `/category/${bcCat?.slug}`;
const bcTitle = title.length > 55 ? title.slice(0, 55) + '…' : title;

// related — same category
const all = await getPosts(50);
const postCatIds = post._embedded?.['wp:term']?.[0]?.map((t: any) => t.id) || [];
const related = all
  .filter((p: any) => {
    if (p.id === post.id) return false;
    const cats = p._embedded?.['wp:term']?.[0]?.map((t: any) => t.id) || [];
    return cats.some((id: number) => postCatIds.includes(id));
  })
  .slice(0, 3);

// FIX: Validate author_url from comment submitters — prevent JSON-LD injection
const safeAuthorUrl = (url: string | undefined): string => {
  if (!url) return 'https://androidscroll.com/';
  try {
    const u = new URL(url);
    if (u.protocol !== 'https:' && u.protocol !== 'http:') return 'https://androidscroll.com/';
    return url;
  } catch {
    return 'https://androidscroll.com/';
  }
};

// Comments come from props (batched in getStaticPaths)

const commentSchema = buildComments.length > 0 ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "DiscussionForumPosting",
  "@id": `https://androidscroll.com/${post.slug}/#comments`,
  "url": `https://androidscroll.com/${post.slug}/`,
  "headline": decode(post.title.rendered.replace(/<[^>]+>/g,'')),
  "name": decode(post.title.rendered.replace(/<[^>]+>/g,'')),
  "text": decode(post.excerpt.rendered.replace(/<[^>]+>/g,'').trim()),
  "datePublished": post.date.endsWith('Z') || post.date.includes('+') ? post.date : post.date + '+00:00',
  "author": {
    "@type": "Person",
    "name": "G-will Chijioke",
    "url": "https://androidscroll.com/about-androidscroll"
  },
  "comment": buildComments.map((c: any) => ({
    "@type": "Comment",
    "dateCreated": c.date.endsWith('Z') || c.date.includes('+') ? c.date : c.date + '+00:00',
    "text": c.content.rendered.replace(/<[^>]+>/g, '').trim(),
    "author": {
      "@type": "Person",
      "name": c.author_name,
      "url": safeAuthorUrl(c.author_url)
    }
  }))
}) : null;
---
<Layout title={title} description={description} cover={cover} coverAlt={coverAlt} coverWidth={coverWidth} coverHeight={coverHeight} type="article" rankMathHead={rankMathHead} commentSchema={commentSchema}>
  <div class="as-progress-container"><div class="as-progress-bar" id="as-progress-bar"></div></div>
  <article style="max-width:780px; margin:auto; background:var(--bg-surface); padding:30px var(--container-side-padding);">
    <!-- Breadcrumb + category pill merged -->
    <nav class="as-breadcrumbs" aria-label="Breadcrumb">
      <a href="/" class="as-bc-home">Home</a>
      <span class="as-bc-sep" aria-hidden="true">›</span>
      {(() => {
        const terms = post._embedded?.['wp:term']?.[0] ?? [];
        const resolved = terms.map((cat: any) => allCats.find((c: any) => c.id === cat.id)).filter(Boolean);
        // Explicitly separate — never rely on WP term order
        const childCat = resolved.find((c: any) => c.parent !== 0);
        const parentCat = childCat
          ? allCats.find((c: any) => c.id === childCat.parent)
          : resolved.find((c: any) => c.parent === 0);
        if (!childCat && !parentCat) return null;
        if (childCat && parentCat) {
          return <>
            <a href={`/category/${parentCat.slug}`} class="as-bc-parent" data-astro-prefetch>{decode(parentCat.name)}</a>
            <span class="as-bc-sep" aria-hidden="true">›</span>
            <a href={`/category/${parentCat.slug}/${childCat.slug}`} class="category_meta-pill" data-astro-prefetch>{decode(childCat.name)}</a>
          </>;
        }
        return <a href={`/category/${parentCat!.slug}`} class="category_meta-pill" data-astro-prefetch>{decode(parentCat!.name)}</a>;
      })()}
    </nav>
  <h1 style="margin-bottom:0.25em;" set:html={post.title.rendered.replace(/<[^>]+>/g, '')}></h1>
  

    <div class="post-meta-block">
      <div class="meta-author-row">
        <a href="/about-androidscroll" class="meta-avatar-link" tabindex="-1" aria-hidden="true">
          <img src={authorAvatar} alt="G-will Chijioke" width="40" height="40" />
        </a>
        <div class="meta-author-details">
          <a href="/about-androidscroll" class="meta-author-name">G-will Chijioke</a>
          <div class="meta-secondary-row">
            <span class="meta-updated-label">
              {isUpdated
                ? `Updated ${modified.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}`
                : date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
              }
            </span>
            <span class="meta-sep" aria-hidden="true">·</span>
            <span class="meta-readtime">{readingTime} min read</span>
          </div>
        </div>
      </div>
    </div>

  
    {cover && (
      <div style="margin:20px 0 30px; border-radius:var(--radius-main); overflow:hidden;">
        <img
          src={cover}
          alt={coverAlt}
          id="featured-image"
          fetchpriority="high"
          loading="eager"
          width={coverWidth ?? undefined}
          height={coverHeight ?? undefined}
          style="width:100%; height:auto; border-radius:var(--radius-main); box-shadow:var(--shadow-soft);"
        />
      </div>
    )}
    
      <!-- Compact Share Row (top) -->
    <div class="as-top-share">
      <span class="as-top-share-label">Share:</span>
      <button id="top-native-share-btn" class="as-tsi" style="display:none;" aria-label="Share">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
      </button>
      <a id="top-share-fb" href="#" target="_blank" rel="noopener noreferrer" class="as-tsi as-tsi-fb" aria-label="Share on Facebook">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      </a>
      <a id="top-share-x" href="#" target="_blank" rel="noopener noreferrer" class="as-tsi as-tsi-x" aria-label="Share on X">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a id="top-share-wa" href="#" target="_blank" rel="noopener noreferrer" class="as-tsi as-tsi-wa" aria-label="Share on WhatsApp">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
      </a>
      <a id="top-share-pinterest" href="#" target="_blank" rel="noopener noreferrer" class="as-tsi as-tsi-pin" aria-label="Share on Pinterest">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
      </a>
      <a id="top-share-threads" href="#" target="_blank" rel="noopener noreferrer" class="as-tsi as-tsi-th" aria-label="Share on Threads">
        <svg width="14" height="14" viewBox="0 0 192 192" fill="currentColor"><path d="M141.537 88.988a66.667 66.667 0 0 0-2.518-1.143c-1.482-27.307-16.403-42.94-41.457-43.1h-.34c-14.986 0-27.449 6.396-35.12 18.036l13.779 9.452c5.73-8.695 14.724-10.548 21.348-10.548h.23c8.249.053 14.474 2.452 18.502 7.13 2.932 3.405 4.893 8.11 5.864 14.05-7.314-1.244-15.224-1.626-23.68-1.14-23.82 1.371-39.134 15.264-38.105 34.568.522 9.792 5.4 18.216 13.735 23.719 7.047 4.652 16.124 6.927 25.557 6.412 12.458-.683 22.231-5.436 29.049-14.127 5.178-6.6 8.453-15.153 9.899-25.93 5.937 3.583 10.337 8.298 12.767 13.966 4.132 9.635 4.373 25.468-8.546 38.376-11.319 11.308-24.925 16.2-45.488 16.351-22.809-.169-40.06-7.484-51.275-21.742C35.236 139.966 29.808 120.682 29.605 96c.203-24.682 5.63-43.966 16.133-57.317C56.954 24.425 74.206 17.11 97.015 16.94c22.975.17 40.526 7.52 52.171 21.847 5.71 7.026 10.015 15.86 12.853 26.162l16.147-4.308c-3.44-12.68-8.853-23.606-16.219-32.668C147.036 9.607 125.202.195 97.105 0h-.113C68.884.195 47.294 9.643 32.79 28.082 19.883 44.485 13.224 67.315 13.001 95.932L13 96v.068c.224 28.617 6.883 51.447 19.79 67.85C47.294 182.358 68.883 191.806 96.992 192h.113c24.96-.173 42.554-6.708 57.048-21.189 18.963-18.945 18.392-42.692 12.142-57.27-4.484-10.454-13.033-18.945-24.758-24.553zM98.44 129.507c-10.44.588-21.286-4.098-21.82-14.135-.397-7.442 5.296-15.745 22.461-16.735 1.966-.113 3.895-.169 5.79-.169 6.235 0 12.068.606 17.371 1.765-1.978 24.702-13.754 28.713-23.802 29.274z"/></svg>
      </a>
    </div>


    <div class="post-content" set:html={contentHtml}></div>

    <!-- Social Share -->
  <div id="as-bottom-share" style="margin:30px 0; padding:20px 0; border-top:1px solid var(--border-light); border-bottom:1px solid var(--border-light);">
    <p style="font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:var(--text-muted); margin-bottom:14px;">Share this post</p>
    <div style="display:flex; flex-wrap:wrap; gap:10px;">
      <button id="native-share-btn" style="display:none; align-items:center; gap:6px; padding:8px 16px; border-radius:var(--radius-main); background:var(--bg-surface-2); border:1.5px solid var(--border-light); color:var(--text-dark); font-size:13px; font-weight:600; cursor:pointer;"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>Share</button>
      <a id="share-fb" href="#" target="_blank" rel="noopener noreferrer" style="display:inline-flex; align-items:center; gap:6px; padding:8px 16px; border-radius:var(--radius-main); background:#1877F2; color:#fff; font-size:13px; font-weight:600; text-decoration:none;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        Facebook
      </a>
      <a id="share-x" href="#" target="_blank" rel="noopener noreferrer" style="display:inline-flex; align-items:center; gap:6px; padding:8px 16px; border-radius:var(--radius-main); background:#000; color:#fff; font-size:13px; font-weight:600; text-decoration:none;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        X
      </a>
      <a id="share-pinterest" href="#" target="_blank" rel="noopener noreferrer" style="display:inline-flex; align-items:center; gap:6px; padding:8px 16px; border-radius:var(--radius-main); background:#E60023; color:#fff; font-size:13px; font-weight:600; text-decoration:none;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
        Pinterest
      </a>
      <a id="share-whatsapp" href="#" target="_blank" rel="noopener noreferrer" style="display:inline-flex; align-items:center; gap:6px; padding:8px 16px; border-radius:var(--radius-main); background:#25D366; color:#fff; font-size:13px; font-weight:600; text-decoration:none;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
