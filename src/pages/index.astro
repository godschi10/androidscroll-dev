---
import Layout from '../layouts/Layout.astro';
import { getPosts, getCategories, decode, excerpt } from '../lib/wp';
import md5 from 'md5';

const AUTHOR_EMAIL = 'godschi10@gmail.com';
const gravatarHash = md5(AUTHOR_EMAIL.trim().toLowerCase());
const authorAvatar = `https://www.gravatar.com/avatar/${gravatarHash}?s=64`;

// ─── EDIT THESE — IDs never change, even when new posts go live ───
const FEATURED_POST_ID  = 12251;              // Paste your WP post ID here
const POPULAR_POST_IDS  = [208,56,9838]; // Up to ~5 IDs, shown in this order
// ──────────────────────────────────────────────────────────────────

const WP_API = 'https://androidscroll.com/wp-json/wp/v2';

// Fetch a single post by ID
async function getPostById(id: number) {
  try {
    const res = await fetch(`${WP_API}/posts/${id}?_embed`);
    return res.ok ? res.json() : null;
  } catch { return null; }
}

// Fetch multiple posts by IDs in one request, returned in your defined order
async function getPostsByIds(ids: number[]) {
  if (!ids.length) return [];
  try {
    const res = await fetch(`${WP_API}/posts?include=${ids.join(',')}&_embed&per_page=${ids.length}`);
    if (!res.ok) return [];
    const data = await res.json();
    // Re-sort to match the order you defined in POPULAR_POST_IDS
    const map = new Map(data.map((p: any) => [p.id, p]));
    return ids.map(id => map.get(id)).filter(Boolean);
  } catch { return []; }
}

// Normalise any WP post object into a clean shape
function mapPost(p: any) {
  return {
    slug: p.slug,
    id:   p.id,
    data: {
      title:       decode(p.title.rendered.replace(/<[^>]+>/g, '')),
      date:        new Date(p.date),
      description: excerpt(p.content.rendered, 22),
      cover:       p._embedded?.['wp:featuredmedia']?.[0]?.source_url || null,
      coverAlt:    decode(p.title.rendered.replace(/<[^>]+>/g, '')),
      categories:  p._embedded?.['wp:term']?.[0] || [],
    }
  };
}

// Fire all network requests in parallel
const [wpPosts, allCats, featuredRaw, popularRaw] = await Promise.all([
  getPosts(12),
  getCategories(),
  getPostById(FEATURED_POST_ID),
  getPostsByIds(POPULAR_POST_IDS),
]);

const parents  = allCats.filter((c: any) => c.parent === 0);
const posts    = wpPosts.map(mapPost);
const featured = featuredRaw ? mapPost(featuredRaw) : null;
const popular  = popularRaw.map(mapPost);

// Latest grid — exclude the featured post so it doesn't appear twice
const recent   = posts.filter((p: any) => p.id !== FEATURED_POST_ID);
---