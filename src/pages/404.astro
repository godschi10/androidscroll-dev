---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found">
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
    <span class="text-8xl font-extrabold text-[#00A88F]">404</span>
    <h1 class="mt-4 text-3xl font-bold text-neutral-900">Page Not Found</h1>
    <p class="mt-3 text-neutral-500 max-w-md">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <div class="mt-8 flex gap-4">
      <a href="/" class="px-6 py-3 bg-[#00A88F] hover:bg-[#008c72] !text-white font-bold rounded-full transition-colors">
        Go Home
      </a>
      <a href="/categories/" class="px-6 py-3 border border-[#00A88F] text-[#00A88F] hover:bg-[#eef9f6] font-bold rounded-full transition-colors">
        Browse Posts
      </a>
    </div>
  </div>
</Layout>