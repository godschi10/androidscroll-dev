---
import Layout from '../../layouts/Layout.astro';
import { getPosts, getPost } from '../../lib/wp';
export async function getStaticPaths(){ return (await getPosts(50)).map(p=>({params:{slug:p.slug}})) }
const post = await getPost(Astro.params.slug);
const title = post.title.rendered.replace(/<[^>]+>/g,'');
const mins = Math.max(1,Math.round(post.content.rendered.replace(/<[^>]+>/g,' ').split(/\s+/).length/200))
---
<Layout title={title} description={post.excerpt.rendered.replace(/<[^>]+>/g,'')}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-3xl md:text-4xl font-bold mb-4" set:html={post.title.rendered}/>
    <div class="text-sm text-neutral-500 mb-8">{new Date(post.date).toDateString()} • {mins} min read</div>
    <div class="prose dark:prose-invert max-w-none" set:html={post.content.rendered}/>
  </article>
</Layout>
