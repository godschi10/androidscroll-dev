---
import Layout from '../../layouts/Layout.astro';
import { getPosts } from '../../lib/wp';
const wpPosts = await getPosts(12);
---
<Layout noindex={true} title="Live WordPress">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-8">Live from WordPress</h1>
    <div class="grid gap-6">
      {wpPosts.map(p => (
        <a href={`/live/${p.slug}/`} class="block p-6 rounded-2xl bg-white dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 hover:border-[#00a88f] transition-all">
          <h2 class="text-xl font-bold" set:html={p.title.rendered}/>
          <p class="text-sm text-neutral-500 mt-2">{new Date(p.date).toLocaleDateString()}</p>
        </a>
      ))}
    </div>
  </div>
</Layout>
