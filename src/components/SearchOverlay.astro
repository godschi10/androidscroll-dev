---
const { posts } = Astro.props;
const searchData = JSON.stringify(posts.map(p => ({
  id: p.id,
  title: p.data.title,
  description: p.data.description ?? '',
  cover: p.data.cover ?? '',
  categories: p.data.categories ?? [],
  url: `/${p.slug}/`,
})));
---

<!-- Search trigger button -->
<button id="search-open" aria-label="Search" style="border:none; background:transparent; cursor:pointer; color:var(--text-dark); display:flex; align-items:center; padding:4px;">
  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
    <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
  </svg>
</button>

<!-- Full screen overlay -->
<div id="search-overlay" style="
  position:fixed; inset:0; z-index:99999;
  background:var(--bg-header);
  display:flex; flex-direction:column;
  opacity:0; pointer-events:none;
  transition:opacity 0.22s ease;
">
  <!-- Top bar -->
  <div style="
    display:flex; align-items:center; gap:12px;
    padding:16px var(--container-side-padding) 12px;
    border-bottom:1px solid var(--border-light);
    flex-shrink:0;
  ">
    <!-- Search input wrapper -->
    <div style="
      flex:1; display:flex; align-items:center; gap:9px;
      background:var(--bg-surface-2);
      border-radius:var(--radius-main);
      padding:10px 13px;
      min-width:0;
    ">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="var(--text-muted)" stroke-width="2" viewBox="0 0 24 24" style="flex-shrink:0;">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        id="search-overlay-input"
        type="search"
        placeholder="Search posts..."
        autocomplete="off"
        style="
          flex:1; min-width:0; border:none; outline:none;
          background:transparent;
          font-family:var(--font-body); font-size:16px;
          color:var(--text-dark);
          padding:0; margin:0;
          -webkit-appearance:none;
        "
      />
      <button id="search-clear" aria-label="Clear" style="
        display:none; align-items:center; justify-content:center;
        width:18px; height:18px; flex-shrink:0;
        border:none; background:var(--text-muted);
        border-radius:50%; cursor:pointer;
        color:#fff; padding:0; font-size:10px;
        line-height:1;
      ">✕</button>
    </div>

    <!-- Dismiss -->
    <button id="search-close" style="
      border:none; background:transparent; cursor:pointer;
      font-family:var(--font-body); font-size:14px; font-weight:600;
      color:var(--brand-primary); padding:8px 0;
      white-space:nowrap; flex-shrink:0;
    ">Cancel</button>
  </div>

  <!-- Results body -->
  <div id="search-body" style="flex:1; overflow-y:auto; padding:16px var(--container-side-padding);">
    <p id="search-hint" style="font-size:14px; color:var(--text-muted); text-align:center; margin-top:40px;">
      Type to search posts...
    </p>
    <div id="search-results-grid" style="display:none; grid-template-columns:1fr 1fr; gap:10px;"></div>
    <p id="search-empty" style="display:none; text-align:center; padding-top:50px; color:var(--text-muted); font-size:15px;"></p>
    <a id="search-view-all" href="/search" style="
      display:none; text-align:center;
      font-size:13px; font-weight:600;
      color:var(--brand-primary);
      padding:14px 0 4px;
      border-top:1px solid var(--border-light);
      text-decoration:none;
      margin-top:10px;
    ">View all results →</a>
  </div>
</div>

<!-- Search data injected as a non-executable JSON block — avoids inline script CSP violations -->
<script id="as-search-data" type="application/json" set:html={searchData}></script>
<script src="/js/search-overlay.js" defer></script>