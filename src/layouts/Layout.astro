---
import '../styles/global.css';
import '../styles/style.min.css';
import SearchOverlay from '../components/SearchOverlay.astro';
import { getPosts, getCategories, decode } from '../lib/wp';

const wpPosts = await getPosts(100);
const posts = wpPosts.map((p: any) => ({
  id: p.slug,
  slug: p.slug,
  data: {
    title: decode(p.title.rendered.replace(/<[^>]+>/g,'')),
    date: new Date(p.date),
    description: decode(p.excerpt.rendered.replace(/<[^>]+>/g,'').trim()),
    cover: p._embedded?.['wp:featuredmedia']?.[0]?.source_url || null,
    coverAlt: decode(p.title.rendered.replace(/<[^>]+>/g,'')),
    draft: false,
    categories: p._embedded?.['wp:term']?.[0]?.map((t: any) => t.slug) || [],
    parentCategory: p._embedded?.['wp:term']?.[0]?.[0]?.slug || null,
  }
})).sort((a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf());

const allCats = await getCategories();
const parents = allCats.filter((c: any) => c.parent === 0);
const children = allCats.filter((c: any) => c.parent !== 0);
const navCategories = parents.map((p: any) => ({
  ...p,
  name: decode(p.name),
  children: children
    .filter((c: any) => c.parent === p.id)
    .map((c: any) => ({ ...c, name: decode(c.name) })),
}));

const { title, description, cover, coverAlt, type = 'website', rankMathHead = null, noindex = false, commentSchema = null, pageSchema = null } = Astro.props;
const siteUrl = 'https://androidscroll.com';
const siteName = 'AndroidScroll';
const defaultDescription = 'Android tips, tricks and guides';
const defaultCover = `${siteUrl}/og-default.jpg`;
const metaTitle = title ? `${title} | ${siteName}` : siteName;
const metaDescription = description ?? defaultDescription;
const metaImage = cover ?? defaultCover;
const metaImageAlt = coverAlt ?? metaTitle;
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const { pathname } = Astro.url;
const isSinglePost = pathname !== '/' && pathname.split('/').filter(Boolean).length === 1;

const socialLinks = [
  { name: 'YouTube',   href: 'https://youtube.com/@androidscroll.',          d: 'M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z' },
