---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#008f79" />
  <link rel="preconnect" href="https://images.androidscroll.com" />
  {cover && <link rel="preload" as="image" href={cover} fetchpriority="high" />}
  <link rel="preload" as="font" type="font/woff2" href="/fonts/space-grotesk-v22-latin-700.woff2" crossorigin />
  <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-v20-latin-regular.woff2" crossorigin />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" href="/AndroidScroll-Favicon.png" />
  <link rel="apple-touch-icon" href="/AndroidScroll-Favicon.png" />

  {rankMathHead ? (
    <Fragment set:html={rankMathHead} />
  ) : (
    <>
      <link rel="canonical" href={canonicalURL} />
      <title>{metaTitle}</title>
      <meta name="description" content={metaDescription} />
      {noindex && <meta name="robots" content="noindex, nofollow" />}
      <meta property="og:type" content={type} />
      <meta property="og:url" content={canonicalURL} />
      <meta property="og:site_name" content={siteName} />
      <meta property="og:title" content={metaTitle} />
      <meta property="og:description" content={metaDescription} />
      <meta property="og:image" content={metaImage} />
      <meta property="og:image:alt" content={metaImageAlt} />
      <meta name="twitter:card" content="summary_large_image" />
      <meta name="twitter:title" content={metaTitle} />
      <meta name="twitter:description" content={metaDescription} />
      <meta name="twitter:image" content={metaImage} />
    </>
  )}

  {commentSchema && (
    <script type="application/ld+json" set:html={commentSchema} />
  )}
  
{pageSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
)}

  <style>
    @font-face { font-family: 'Space Grotesk'; font-style: normal; font-weight: 700; font-display: swap; src: url('/fonts/space-grotesk-v22-latin-700.woff2') format('woff2'); }
    @font-face { font-family: 'Space Grotesk'; font-style: normal; font-weight: 600; font-display: swap; src: url('/fonts/space-grotesk-v22-latin-600.woff2') format('woff2'); }
    @font-face { font-family: 'Inter'; font-style: normal; font-weight: 400; font-display: swap; src: url('/fonts/inter-v20-latin-regular.woff2') format('woff2'); }
    @font-face { font-family: 'Inter'; font-style: normal; font-weight: 600; font-display: swap; src: url('/fonts/inter-v20-latin-600.woff2') format('woff2'); }


    /* Dropdown */
    .nav-dropdown { position: relative; }

    .nav-dropdown-menu {
      display: none;
      position: absolute;
      top: calc(100% + 8px);
      left: 50%;
      transform: translateX(-50%);
      background: var(--bg-surface);
      border: 1px solid var(--border-light);
      border-radius: 12px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.12);
      min-width: 600px;
      padding: 16px;
      z-index: 200;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }
    .nav-dropdown-menu.open { display: grid !important; }
    .dropdown-col { display: flex; flex-direction: column; gap: 4px; }
    .dropdown-parent-link {
      font-size: 11px; font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--brand-primary);
      text-decoration: none; padding: 6px 10px;
      border-radius: 6px; transition: background 0.15s;
    }
    .dropdown-parent-link:hover { background: var(--bg-surface-2); }
    .dropdown-child-link {
      font-size: 13px; font-weight: 500; color: var(--text-main);
      text-decoration: none; padding: 5px 10px;
      border-radius: 6px; transition: background 0.15s, color 0.15s;
    }
    .dropdown-child-link:hover { background: var(--bg-surface-2); color: var(--brand-primary); }

    /* Mobile menu */
    .mobile-cat-toggle { cursor: pointer; display: flex; justify-content: space-between; align-items: center; width: 100%; }
    .mobile-cat-children { display: none; flex-direction: column; background: var(--bg-surface-2); }
    .mobile-cat-children.open { display: flex; }
    .mobile-child-link { padding: 11px var(--container-side-padding) 11px calc(var(--container-side-padding) + 16px); font-size: 13px; color: var(--text-muted); text-decoration: none; border-bottom: 1px solid var(--border-light); }
    .mobile-child-link:hover { color: var(--brand-primary); }

    /* Social icons */
    .social-icons { display: flex; align-items: center; gap: 4px; }
    .social-icon {
      display: flex; align-items: center; justify-content: center;
      width: 28px; height: 28px; border-radius: 6px;
      color: var(--text-muted); transition: color 0.15s, background 0.15s;
      text-decoration: none;
    }
    .social-icon:hover { color: var(--brand-primary); background: var(--bg-surface-2); }
    .social-icon svg { width: 14px; height: 14px; fill: currentColor; flex-shrink: 0; }

    /* Footer social icons */
    .footer-social-icons { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 16px; }
    .footer-social-icon {
      display: flex; align-items: center; justify-content: center;
      width: 32px; height: 32px; border-radius: 8px;
      background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.6);
      transition: background 0.15s, color 0.15s; text-decoration: none;
    }
    .footer-social-icon:hover { background: var(--brand-primary); color: #fff; }
    .footer-social-icon svg { width: 15px; height: 15px; fill: currentColor; flex-shrink: 0; }

    /* Mobile menu social icons */
    .mobile-social-row { display: flex; flex-wrap: wrap; justify-content: center; gap: 8px; padding: 16px var(--container-side-padding); border-top: 1px solid var(--border-light); }
    .mobile-social-icon {
      display: flex; align-items: center; justify-content: center;
      width: 36px; height: 36px; border-radius: 8px;
      background: var(--bg-surface-2); color: var(--text-muted);
      transition: background 0.15s, color 0.15s; text-decoration: none;
    }
    .mobile-social-icon:hover { background: var(--brand-primary); color: #fff; }
    .mobile-social-icon svg { width: 16px; height: 16px; fill: currentColor; flex-shrink: 0; }
  </style>


</head>
<body>

<!-- HEADER -->
<header style="background:var(--bg-header); border-bottom:1px solid var(--border-light); position:sticky; top:0; z-index:100; padding:2.5px 0;">
  <nav style="max-width:1180px; margin:auto; padding:0 var(--container-side-padding); height:56px; display:flex; align-items:center; justify-content:space-between;">

    <!-- Logo -->
    <a href="/" style="flex-shrink:0;">
      <img src="https://images.androidscroll.com/2026/01/cropped-Androidscroll-Logo-1.png" alt="AndroidScroll" width="160" height="40" style="max-height:38px; max-width:170px; display:block;" />
    </a>

    <!-- Desktop Nav -->
    <ul class="desktop-nav" style="display:none; list-style:none; margin:0; padding:0; gap:4px; align-items:center; font-size:13px; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; width:max-content;">

      <!-- Categories Dropdown -->
      <li style="position:relative; z-index:10;" id="categories-dropdown">
        <button id="dd-button" aria-expanded="false" style="position:relative; z-index:20; display:flex; align-items:center; gap:8px; padding:10px 16px; white-space:nowrap; cursor:pointer; background:none; border:none; color:var(--text-main); font-family:var(--font-heading); font-size:13px; font-weight:700; text-transform:uppercase; letter-spacing:0.05em;">
          Categories
          <svg style="pointer-events:none;" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div id="dd-menu" style="display:none; position:absolute; top:100%; left:0; z-index:30; background:var(--bg-surface); border:1px solid var(--border-light); border-radius:12px; box-shadow:0 8px 32px rgba(0,0,0,0.12); width:560px; max-width:90vw; padding:16px; grid-template-columns:repeat(3, minmax(0, 1fr)); gap:16px;">
          {navCategories.map((cat: any) => (
            <div style="display:flex; flex-direction:column; gap:4px;">
              <a href={`/category/${cat.slug}`} style="font-size:11px; font-weight:800; text-transform:uppercase; letter-spacing:0.08em; color:var(--brand-primary); text-decoration:none; padding:6px 10px; border-radius:6px;">{cat.name}</a>
              {cat.children.map((child: any) => (
                <a href={`/category/${cat.slug}/${child.slug}`} style="font-size:13px; font-weight:500; color:var(--text-main); text-decoration:none; padding:5px 10px; border-radius:6px;">{child.name}</a>
              ))}
            </div>
          ))}
        </div>
      </li>

      <li><a href="/start-here" style="color:var(--text-main); text-decoration:none; transition:color 0.15s; margin-right:15px;">Start Here</a></li>
      <li><a href="/about-androidscroll" style="color:var(--text-main); text-decoration:none; transition:color 0.15s;">About</a></li>

      <!-- Desktop Social Icons -->
      <li style="display:flex; align-items:center; padding-left:12px; margin-left:8px; border-left:1px solid var(--border-light);">
        <div class="social-icons">
          {socialLinks.map((s) => (
            <a href={s.href} class="social-icon" target="_blank" rel="noopener noreferrer" aria-label={s.name}>
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d={s.d}/></svg>
            </a>
          ))}
        </div>
      </li>
    </ul>

    <!-- Right: Search + Hamburger -->
    <div style="display:flex; align-items:center; gap:12px;">
      <SearchOverlay posts={posts} />
      <button id="menu-toggle" aria-label="Toggle menu" style="border:none; background:transparent; cursor:pointer; display:flex; flex-direction:column; gap:3px; padding:4px;margin-left:10px">
        <span style="display:block; width:18px; height:2px; background:var(--text-main);"></span>
        <span style="display:block; width:18px; height:2px; background:var(--text-main);"></span>
        <span style="display:block; width:18px; height:2px; background:var(--text-main);"></span>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
